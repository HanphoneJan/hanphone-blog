LOCATION_KEY=XXXXXX # 替换为自己的地图定位key
LOCATION_URL=https://apis.map.qq.com/ws/location/v1/ip

NEXT_PUBLIC_API_BASE_URL=https://hanphone.cn/api
NEXT_PUBLIC_NEXT_API_BASE_URL=https://hanphone.cn/next-api

# 图片/文件服务域名（不带 www，用于文件存储和图片访问）
NEXT_PUBLIC_FILE_DOMAIN=hanphone.top
NEXT_PUBLIC_PICTURE_BASE_URL=https://hanphone.top

# 站点主域名（带 www，用于 SEO 和规范链接）
NEXT_PUBLIC_SITE_URL=https://hanphone.cn

# 主域名（用于 middleware 重定向，不带协议）
PRIMARY_DOMAIN=hanphone.cn

NEXT_PUBLIC_FOOTER_QR_IMAGE=https://hanphone.top/images/云林有风公众号.jpg
NEXT_PUBLIC_FOOTER_EMAIL=janhizian@qq.com
NEXT_PUBLIC_FOOTER_GITHUB=https://github.com/HanphoneJan/
NEXT_PUBLIC_FOOTER_BILIBILI=https://space.bilibili.com/649062555/
NEXT_PUBLIC_FOOTER_ICP_URL=https://beian.miit.gov.cn/
NEXT_PUBLIC_FOOTER_ICP_NUMBER=粤ICP备2024325722号-2

# Live2D 看板娘移动端显示控制（"true" 显示，"false" 隐藏，默认 true）
NEXT_PUBLIC_LIVE2D_MOBILE=true

# 站点起始运行时间（ISO 8601 格式，用于 footer 显示运行时长）
NEXT_PUBLIC_SITE_START_DATE=2025-01-01T00:00:00+08:00