{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "hanphone",
  "version": "1.0.0",
  "identifier": "cn.hanphone.blog",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": {
      "script": "pnpm build:tauri",
      "cwd": ".."
    },
    "devUrl": "http://localhost:3000",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "寒枫的博客",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "focus": true,
        "visible": true,
        "decorations": true,
        "devtools": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["msi","nsis","deb", "rpm", "appimage","app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "wix": {
        "language": "zh-CN"
      }
    }
  }
}
