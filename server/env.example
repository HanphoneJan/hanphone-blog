# Spring Profile: dev (开发环境) 或 prod (生产环境)
SPRING_PROFILES_ACTIVE=prod

# JWT 配置
TOKEN_SECRET=xxxxxx
JWT_ISSUER=auth0
JWT_EXPIRE_TIME=604800000

# 数据库配置
PG_HOST=localhost
PG_USERNAME=postgres
PG_PASSWORD=xxxxx

# 邮箱配置
EMAIL_FROM_NAME=xxxxx
EMAIL_USERNAME=xxxxx@163.com
EMAIL_PASSWORD=xxxxx
EMAIL_HOST=smtp.163.com

# Redis 配置
REDIS_PORT=6379
REDIS_HOST=localhost
REDIS_PASSWORD=xxxxxx

# 服务器配置
SERVER_PORT=8090

# 内部服务通信密钥（hanphone-chat 调用 /api/** 接口时使用）
# 与 hanphone-chat server/.env 中的 BLOG_INTERNAL_KEY 保持一致
INTERNAL_API_KEY=your_internal_api_key_here

CORS_ALLOWED_ORIGINS=https://hanphone.cn,https://www.hanphone.cn,http://localhost:8080,http://localhost:3000,http://localhost:*,tauri://localhost

# GitHub OAuth 配置
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=https://hanphone.cn/api/oauth/github/callback
# Google OAuth 配置
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://hanphone.cn/api/oauth/google/callback
# Google OAuth 代理（国内服务器需配置，用于访问 oauth2.googleapis.com）
GOOGLE_OAUTH_PROXY_HOST=
GOOGLE_OAUTH_PROXY_PORT=0
